# OpenAI-compatible chat completion endpoint.
VITE_DEFAULT_PROVIDER="OpenAI Compatible"
VITE_DEFAULT_ENDPOINT="https://api.openai.com/v1/chat/completions"
VITE_DEFAULT_MODEL="gpt-4o-mini"

# Keep this empty in committed files. Put a real key only in your local .env file.
VITE_DEFAULT_API_KEY=""

# 认证后端地址。前端需要指向正在运行的认证服务。
VITE_AUTH_BASE_URL="http://127.0.0.1:8787"

# 认证服务配置示例
# AUTH_SERVER_PORT="8787"
# AUTH_APP_ORIGIN="http://localhost:5173"
# AUTH_SMTP_HOST="smtp.example.com"
# AUTH_SMTP_PORT="465"
# AUTH_SMTP_USER="no-reply@example.com"
# AUTH_SMTP_PASS="你的邮箱授权码"
# AUTH_SMTP_FROM="AI Prompt Project <no-reply@example.com>"
